{
  "workspace": [
    "./packages/common",
    "./packages/kernel",
    "./packages/runtime",
    "./packages/exceptions",
    "./packages/di-plugin",
    "./packages/decorator-plugin",
    "./packages/logger-plugin",
    "./packages/config-plugin",
    "./packages/validation-plugin",
    "./packages/database-plugin",
    "./packages/cache-plugin",
    "./packages/events-plugin",
    "./packages/cqrs-plugin",
    "./packages/messaging-plugin",
    "./packages/queue-plugin",
    "./packages/auth-plugin",
    "./packages/http-security-plugin",
    "./packages/scheduler-plugin",
    "./packages/metrics-plugin",
    "./packages/health-plugin",
    "./packages/openapi-plugin",
    "./packages/telemetry-plugin",
    "./packages/secrets-plugin",
    "./packages/audit-plugin",
    "./packages/resilience-plugin",
    "./packages/storage-plugin",
    "./packages/mail-plugin",
    "./packages/notification-plugin",
    "./packages/feature-flags-plugin",
    "./packages/multi-tenancy-plugin",
    "./packages/testing",
    "./packages/cli",
    "./packages/sdk",
    "./packages/starters/rest-starter",
    "./packages/starters/microservice-starter",
    "./packages/starters/full-stack-starter",
    "./packages/sse-plugin"
  ],
  "tasks": {
    "check": "deno check packages",
    "check:plan": "deno run --allow-read scripts/plan-lint.ts",
    "test": "deno test -P --allow-read --allow-import --allow-env --allow-sys=hostname packages",
    "test:coverage": "rm -rf coverage && deno test -P --allow-read --allow-import --allow-env --allow-sys=hostname packages --coverage=coverage && deno run --allow-run=deno scripts/coverage.ts",
    "audit": "deno audit --level=high",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check"
  },
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "include": [
        "no-eval",
        "no-sync-fn-in-async-fn",
        "no-console",
        "verbatim-module-syntax"
      ]
    }
  },
  "fmt": {
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": true,
    "semiColons": true,
    "exclude": ["docs/api", ".verify", ".verify-milestone"]
  },
  "imports": {
    "@std/expect": "jsr:@std/expect@^1.0.20",
    "@std/testing": "jsr:@std/testing@^1.0.19"
  }
}
