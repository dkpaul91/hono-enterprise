# Coverage output (root `deno task test:coverage` writes coverage/; per-package
# runs with `--coverage=.coverage` write .coverage/ — ignore both at any depth).
coverage/
.coverage/

# Generated API docs
docs/api/

# npm compatibility artifacts (compat test suites)
node_modules/

# Environment files
.env
.env.*
!.env.example

# Editor/OS noise
.DS_Store
.idea/
*.swp

# Claude Code local state (worktree checkouts, personal settings). Nothing
# under .claude/ is meant to be tracked today; if shared project config is
# added later (e.g. .claude/settings.json), un-ignore it with a negation.
.claude/
